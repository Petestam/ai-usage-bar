{
  "name": "ai-usage-bar",
  "version": "1.3.0",
  "description": "Mac menubar app that tracks AI service usage limits",
  "author": "AI Usage Bar",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --universal --publish never",
    "build:arm64": "electron-builder --mac --arm64",
    "build:x64": "electron-builder --mac --x64",
    "test:cursor": "node scripts/test-cursor-usage.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "menubar": "^9.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "xyz.nohotashes.ai-usage-bar",
    "productName": "AI Usage",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "debug.js",
      "icon.js",
      "poller.js",
      "store.js",
      "providers/**",
      "renderer/**",
      "node_modules/**"
    ]
  }
}
